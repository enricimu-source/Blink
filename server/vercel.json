{
    "version" : 2,
    "name" : "Blink",
    "builds" : [
        {
            "src" : "./index.js",
            "use" : "@vercel/node"
        }
    ],
    "routes" : [
        {
            "src" : "/(.*)",
            "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
            "dest": "/index.html"
        }
    ]
}     